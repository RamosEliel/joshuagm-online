# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# Optional (recomendado en Vercel con poolers/pgbouncer)
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo"

# One-time setup (dev only)
# Se envia en header: x-setup-token
SETUP_TOKEN="cambia-esto"
ADMIN_EMAIL="admin@joshuagm.com"
ADMIN_PASSWORD="cambia-esto"

# Solo para primer despliegue (temporal): permite /api/setup en produccion
ALLOW_PROD_SETUP="false"
